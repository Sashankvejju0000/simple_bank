          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"Alice Vance\",\n  \"Mobile_No\": \"555-0100\",\n  \"address\": \"456 Pine Rd, Bellevue, WA\"\n}",
              "options": {
                "raw": {
